                    { "type": "barChart", "axis": "ligne_production", "values": ["Quantité Produite", "Nb Incidents"] }
                ]},
                { "name": "Supply Chain", "visuals": [
                    { "type": "card", "measure": "Délai Moyen Livraison" }, { "type": "card", "measure": "Taux Retard Fournisseurs %" },
                    { "type": "barChart", "axis": "fournisseur_id", "values": ["Taux Retard Fournisseurs %"] }
                ]}
            ], "filters": ["annee", "mois", "ligne_production"]
        },
        {
            "name": "rpt_process_sanitaire", "displayName": "Process Sanitaire", "semanticModel": "SM_Operations",
            "pages": [
