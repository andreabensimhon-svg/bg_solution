/// BGSolutions - Semantic Model TMDL
/// Modèle sémantique Power BI pour toutes les entités métier
/// Format : Tabular Model Definition Language (TMDL)

model BGSolutions_SemanticModel

    culture: fr-FR
    defaultPowerBIDataSourceVersion: powerBI_V3
    discourageImplicitMeasures

    /// ============================================
    /// TABLES
    /// ============================================

    table fact_marges
        lineageTag: "fact-marges"
        sourceLineageTag: [gold].[fact_marges]
        partition 'fact_marges' = entity
            entityName: fact_marges
            schemaName: gold

        column marge_id
            dataType: int64
            isHidden
            sourceColumn: marge_id

        column date_calcul
            dataType: dateTime
            formatString: dd/MM/yyyy
            sourceColumn: date_calcul

        column annee
            dataType: int64
            sourceColumn: annee

        column mois
            dataType: int64
            sourceColumn: mois

        column trimestre
            dataType: int64
            sourceColumn: trimestre

        column client_id
            dataType: int64
            isHidden
            sourceColumn: client_id

        column produit_id
            dataType: int64
            isHidden
            sourceColumn: produit_id

        column categorie_produit
            dataType: string
            sourceColumn: categorie_produit

        column chiffre_affaires_ht
            dataType: decimal
            formatString: #,##0.00 €
            sourceColumn: chiffre_affaires_ht

        column cout_revient
            dataType: decimal
            sourceColumn: cout_revient

        column marge_brute
            dataType: decimal
            formatString: #,##0.00 €
            sourceColumn: marge_brute

        column marge_brute_pct
            dataType: decimal
            formatString: 0.00%
            sourceColumn: marge_brute_pct

        column volume_vendu
            dataType: int64
            sourceColumn: volume_vendu

    table fact_ventes
        lineageTag: "fact-ventes"
        sourceLineageTag: [gold].[fact_ventes]
        partition 'fact_ventes' = entity
            entityName: fact_ventes
            schemaName: gold

        column date_vente
            dataType: dateTime
            formatString: dd/MM/yyyy
            sourceColumn: date_vente

        column client_id
            dataType: int64
            isHidden
            sourceColumn: client_id

        column produit_id
            dataType: int64
            isHidden
            sourceColumn: produit_id

        column type_client
            dataType: string
            sourceColumn: type_client

        column categorie_produit
            dataType: string
            sourceColumn: categorie_produit

        column canal_vente
            dataType: string
            sourceColumn: canal_vente

        column nb_commandes
            dataType: int64
            sourceColumn: nb_commandes

        column quantite_totale
            dataType: int64
            sourceColumn: quantite_totale

        column ca_brut_ht
            dataType: decimal
            formatString: #,##0.00 €
            sourceColumn: ca_brut_ht

        column ca_net_ht
            dataType: decimal
            formatString: #,##0.00 €
            sourceColumn: ca_net_ht

        column panier_moyen
            dataType: decimal
            formatString: #,##0.00 €
            sourceColumn: panier_moyen

    table fact_production
        lineageTag: "fact-production"
        sourceLineageTag: [gold].[fact_production]
        partition 'fact_production' = entity
            entityName: fact_production
            schemaName: gold

        column date_production
            dataType: dateTime
            sourceColumn: date_production

        column ligne_production
            dataType: string
            sourceColumn: ligne_production

        column nb_ordres
            dataType: int64
            sourceColumn: nb_ordres

        column quantite_produite_total
            dataType: int64
            sourceColumn: quantite_produite_total

        column taux_rendement_moyen
            dataType: decimal
            formatString: 0.00%
            sourceColumn: taux_rendement_moyen

        column nb_incidents
            dataType: int64
            sourceColumn: nb_incidents

    table fact_iot_realtime
        lineageTag: "fact-iot"
        sourceLineageTag: [gold].[fact_iot_realtime]
        partition 'fact_iot_realtime' = entity
            entityName: fact_iot_realtime
            schemaName: gold

        column window_start
            dataType: dateTime
            sourceColumn: window_start

        column capteur_id
            dataType: string
            sourceColumn: capteur_id

        column type_mesure
            dataType: string
            sourceColumn: type_mesure

        column valeur_moyenne
            dataType: double
            sourceColumn: valeur_moyenne

        column has_anomalie
            dataType: boolean
            sourceColumn: has_anomalie

    table dim_products
        lineageTag: "dim-products"
        sourceLineageTag: [gold].[dim_products]
        partition 'dim_products' = entity
            entityName: dim_products
            schemaName: gold

        column produit_id
            dataType: int64
            isKey
            sourceColumn: produit_id

        column nom_produit
            dataType: string
            sourceColumn: nom_produit

        column categorie
            dataType: string
            sourceColumn: categorie

        column sous_categorie
            dataType: string
            sourceColumn: sous_categorie

        column prix_catalogue_ht
            dataType: decimal
            formatString: #,##0.00 €
            sourceColumn: prix_catalogue_ht

    table fact_clients
        lineageTag: "fact-clients"
        sourceLineageTag: [gold].[fact_clients]
        partition 'fact_clients' = entity
            entityName: fact_clients
            schemaName: gold

        column client_id
            dataType: int64
            isKey
            sourceColumn: client_id

        column raison_sociale
            dataType: string
            sourceColumn: raison_sociale

        column type_client
            dataType: string
            sourceColumn: type_client

        column ville
            dataType: string
            sourceColumn: ville

        column ca_cumule_ht
            dataType: decimal
            formatString: #,##0.00 €
            sourceColumn: ca_cumule_ht

        column categorie_abc
            dataType: string
            sourceColumn: categorie_abc

    table dim_bilans_comptables
        lineageTag: "dim-bilans"
        sourceLineageTag: [gold].[dim_bilans_comptables]
        partition 'dim_bilans_comptables' = entity
            entityName: dim_bilans_comptables
            schemaName: gold

        column annee_fiscale
            dataType: int64
            sourceColumn: annee_fiscale

        column type_bilan
            dataType: string
            sourceColumn: type_bilan

        column poste_comptable
            dataType: string
            sourceColumn: poste_comptable

        column montant
            dataType: decimal
            formatString: #,##0.00 €
            sourceColumn: montant

        column variation_pct
            dataType: decimal
            formatString: 0.00%
            sourceColumn: variation_pct

    /// ============================================
    /// RELATIONS
    /// ============================================

    relationship rel_marges_clients
        fromColumn: fact_marges.client_id
        toColumn: fact_clients.client_id

    relationship rel_marges_produits
        fromColumn: fact_marges.produit_id
        toColumn: dim_products.produit_id

    relationship rel_ventes_clients
        fromColumn: fact_ventes.client_id
        toColumn: fact_clients.client_id

    relationship rel_ventes_produits
        fromColumn: fact_ventes.produit_id
        toColumn: dim_products.produit_id
