{
    "reports": [
        {
            "name": "rpt_finance_marges_forecast",
            "displayName": "Marges & Forecast",
            "entity": "Finance",
            "description": "Évolution des marges, prévisions financières et alertes",
            "pages": [
                {
                    "name": "Vue d'ensemble",
                    "visuals": [
                        { "type": "card", "measure": "CA Total HT", "title": "CA Total" },
                        { "type": "card", "measure": "Marge Brute %", "title": "Marge Brute" },
                        { "type": "card", "measure": "Croissance CA %", "title": "Croissance" },
                        { "type": "lineChart", "axis": "date_calcul", "values": ["CA Total HT", "Forecast CA"], "title": "CA vs Forecast" },
                        { "type": "barChart", "axis": "categorie_produit", "values": ["Marge Brute Totale"], "title": "Marge par catégorie" },
                        { "type": "table", "columns": ["annee", "mois", "CA Total HT", "Marge Brute %", "Écart Forecast %"] }
                    ]
                },
                {
                    "name": "Détail Marges",
                    "visuals": [
                        { "type": "matrix", "rows": ["categorie_produit", "nom_produit"], "values": ["CA Total HT", "Marge Brute Totale", "Marge Brute %"] },
                        { "type": "waterfallChart", "category": "mois", "values": ["Marge Brute Totale"], "title": "Waterfall Marge mensuelle" }
                    ]
                }
            ],
            "filters": ["annee", "trimestre", "categorie_produit"]
        },
        {
            "name": "rpt_finance_bilans",
            "displayName": "Bilans Comptables",
            "entity": "Finance",
            "description": "3 bilans comptables annuels avec variation N-1",
            "pages": [
                {
                    "name": "Bilan Actif/Passif",
                    "visuals": [
                        { "type": "matrix", "rows": ["type_bilan", "poste_comptable"], "columns": ["annee_fiscale"], "values": ["montant", "variation_pct"] },
                        { "type": "clusteredBarChart", "axis": "poste_comptable", "legend": "annee_fiscale", "values": ["montant"] }
                    ]
                },
                {
                    "name": "Compte de Résultat",
                    "visuals": [
                        { "type": "table", "filter": "type_bilan = resultat", "columns": ["poste_comptable", "montant", "montant_n_moins_1", "variation_pct"] }
                    ]
                }
            ],
            "filters": ["annee_fiscale", "type_bilan"]
        },
        {
            "name": "rpt_operations_production",
            "displayName": "Production & Supply Chain",
            "entity": "Opérations",
            "description": "KPIs production, suivi supply chain",
            "pages": [
                {
                    "name": "Production",
                    "visuals": [
                        { "type": "card", "measure": "Taux Rendement Moyen", "title": "Rendement" },
                        { "type": "card", "measure": "Nb Incidents", "title": "Incidents" },
                        { "type": "lineChart", "axis": "date_production", "values": ["Taux Rendement Moyen"], "title": "Rendement dans le temps" },
                        { "type": "barChart", "axis": "ligne_production", "values": ["Quantité Produite", "Nb Incidents"] }
                    ]
                },
                {
                    "name": "Supply Chain",
                    "visuals": [
                        { "type": "card", "measure": "Délai Moyen Livraison", "title": "Délai moyen" },
                        { "type": "card", "measure": "Taux Retard Fournisseurs %", "title": "Taux retard" },
                        { "type": "barChart", "axis": "fournisseur_id", "values": ["Taux Retard Fournisseurs %"], "title": "Retard par fournisseur" }
                    ]
                }
            ],
            "filters": ["annee", "mois", "ligne_production"]
        },
        {
            "name": "rpt_operations_sanitaire",
            "displayName": "Process Sanitaire",
            "entity": "Opérations",
            "description": "Conformité et suivi process sanitaire",
            "pages": [
                {
                    "name": "Conformité",
                    "visuals": [
                        { "type": "gauge", "measure": "Taux Conformité Sanitaire %", "target": 98, "title": "Conformité" },
                        { "type": "card", "measure": "Nb Non Conformités", "title": "Non conformités" },
                        { "type": "card", "measure": "Nb Alertes Sanitaires", "title": "Alertes" },
                        { "type": "lineChart", "axis": "date_periode", "values": ["Taux Conformité Sanitaire %"], "title": "Évolution conformité" },
                        { "type": "matrix", "rows": ["ligne_production", "type_controle"], "values": ["nb_controles", "taux_conformite_pct"] }
                    ]
                }
            ],
            "filters": ["annee", "ligne_production", "type_controle"]
        },
        {
            "name": "rpt_sales_ventes",
            "displayName": "Ventes B2B",
            "entity": "Sales",
            "description": "Performance ventes, distribution",
            "pages": [
                {
                    "name": "Vue d'ensemble",
                    "visuals": [
                        { "type": "card", "measure": "CA Net HT", "title": "CA Net" },
                        { "type": "card", "measure": "Nb Commandes", "title": "Commandes" },
                        { "type": "card", "measure": "Panier Moyen", "title": "Panier moyen" },
                        { "type": "card", "measure": "Nb Clients Actifs", "title": "Clients actifs" },
                        { "type": "lineChart", "axis": "date_vente", "values": ["CA Net HT"], "title": "Évolution CA" },
                        { "type": "donutChart", "legend": "canal_vente", "values": ["CA Net HT"], "title": "CA par canal" }
                    ]
                },
                {
                    "name": "Analyse Clients",
                    "visuals": [
                        { "type": "barChart", "axis": "raison_sociale", "values": ["CA Net HT"], "topN": 20 },
                        { "type": "pieChart", "legend": "categorie_abc", "values": ["Nb Clients Actifs"], "title": "Répartition ABC" },
                        { "type": "scatterChart", "xAxis": "nb_commandes_total", "yAxis": "ca_cumule_ht", "legend": "categorie_abc" }
                    ]
                }
            ],
            "filters": ["annee", "trimestre", "type_client", "canal_vente", "categorie_produit"]
        },
        {
            "name": "rpt_sales_grands_comptes",
            "displayName": "Grands Comptes",
            "entity": "Sales",
            "description": "Suivi dédié grands comptes",
            "pages": [
                {
                    "name": "Suivi",
                    "visuals": [
                        { "type": "card", "measure": "Part Grands Comptes %", "title": "Part CA" },
                        { "type": "lineChart", "axis": "date_periode", "values": ["ca_mensuel_ht", "objectif_mensuel"], "title": "CA vs Objectif" },
                        { "type": "table", "columns": ["raison_sociale", "ca_mensuel_ht", "ca_cumul_annee", "atteinte_objectif_pct", "nb_commandes"] }
                    ]
                }
            ],
            "filters": ["annee", "raison_sociale"]
        }
    ]
}
