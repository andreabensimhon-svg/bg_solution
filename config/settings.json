{
    "project": {
        "name": "BGSolutions",
        "version": "1.0.0",
        "description": "Plateforme Data Microsoft Fabric - Matériaux carrosserie"
    },
    "fabric": {
        "workspace_id": "${FABRIC_WORKSPACE_ID}",
        "lakehouse_id": "${FABRIC_LAKEHOUSE_ID}",
        "lakehouse_name": "lh_bgsolutions",
        "warehouse_name": "wh_bgsolutions"
    },
    "connections": {
        "erp": {
            "server": "${ERP_SQL_SERVER}",
            "database": "${ERP_SQL_DATABASE}",
            "auth_type": "ServicePrincipal"
        },
        "clients_db": {
            "server": "${CLIENTS_SQL_SERVER}",
            "database": "${CLIENTS_SQL_DATABASE}",
            "auth_type": "ServicePrincipal"
        },
        "cosmos_db": {
            "endpoint": "${COSMOS_ENDPOINT}",
            "database": "bgsolutions"
        },
        "json_api": {
            "base_url": "${JSON_API_BASE_URL}",
            "auth_type": "OAuth2"
        }
    },
    "key_vault": {
        "name": "${KEY_VAULT_NAME}",
        "secrets": [
            "erp-sql-sp-secret",
            "clients-sql-sp-secret",
            "cosmos-db-key",
            "json-api-client-secret",
            "mail-sp-secret"
        ]
    },
    "service_principal": {
        "tenant_id": "${AZURE_TENANT_ID}",
        "client_id": "${SP_CLIENT_ID}"
    },
    "schedules": {
        "pipeline_orchestrator": {
            "cron": "0 3 * * *",
            "timezone": "Europe/Paris",
            "description": "Pipeline principal quotidien à 3h du matin"
        },
        "delta_maintenance": {
            "cron": "0 1 * * 0",
            "timezone": "Europe/Paris",
            "description": "Maintenance Delta tables chaque dimanche à 1h"
        },
        "ml_anomaly_detection": {
            "cron": "0 6 * * *",
            "timezone": "Europe/Paris",
            "description": "Détection anomalies IoT quotidienne à 6h"
        },
        "ml_forecast": {
            "cron": "0 5 1 * *",
            "timezone": "Europe/Paris",
            "description": "Recalcul forecast ventes le 1er de chaque mois"
        }
    },
    "data_quality": {
        "max_null_pct_key_columns": 0,
        "max_duplicate_pct": 1,
        "freshness_max_hours": {
            "bronze": 24,
            "silver": 24,
            "gold": 48
        }
    },
    "iot": {
        "eventstream_name": "es_iot_capteurs",
        "kql_database": "db_iot_realtime",
        "aggregation_window": "5 minutes",
        "retention_days": {
            "raw": 30,
            "aggregated": 365
        },
        "seuils": {
            "temperature": { "min": -10, "max": 200, "warning": 150, "critical": 180, "unite": "celsius" },
            "pression":    { "min": 0,   "max": 500, "warning": 300, "critical": 400, "unite": "bar" },
            "humidite":    { "min": 0,   "max": 100, "warning": 85,  "critical": 95,  "unite": "pct" }
        }
    }
}
