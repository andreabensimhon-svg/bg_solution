{
    "openapi": "3.0.3",
    "info": {
        "title": "BGSolutions Data API",
        "description": "API pour exposer les données de la plateforme BGSolutions aux systèmes tiers",
        "version": "1.0.0",
        "contact": {
            "name": "BGSolutions IT"
        }
    },
    "servers": [
        {
            "url": "https://{workspace}.fabric.microsoft.com/api/v1",
            "description": "Fabric API endpoint"
        }
    ],
    "paths": {
        "/clients": {
            "get": {
                "summary": "Liste des clients",
                "operationId": "getClients",
                "tags": ["Clients"],
                "parameters": [
                    { "name": "type_client", "in": "query", "schema": { "type": "string", "enum": ["grand_compte", "garage_independant", "distributeur", "concessionnaire"] } },
                    { "name": "categorie_abc", "in": "query", "schema": { "type": "string", "enum": ["A", "B", "C"] } },
                    { "name": "ville", "in": "query", "schema": { "type": "string" } },
                    { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50, "maximum": 500 } },
                    { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
                ],
                "responses": {
                    "200": {
                        "description": "Liste des clients",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": { "type": "array", "items": { "$ref": "#/components/schemas/Client" } },
                                        "total": { "type": "integer" },
                                        "limit": { "type": "integer" },
                                        "offset": { "type": "integer" }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/clients/{client_id}": {
            "get": {
                "summary": "Détail d'un client",
                "operationId": "getClientById",
                "tags": ["Clients"],
                "parameters": [
                    { "name": "client_id", "in": "path", "required": true, "schema": { "type": "integer" } }
                ],
                "responses": {
                    "200": { "description": "Détail client", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClientDetail" } } } },
                    "404": { "description": "Client non trouvé" }
                }
            }
        },
        "/finance/kpis": {
            "get": {
                "summary": "KPIs financiers",
                "operationId": "getFinanceKPIs",
                "tags": ["Finance"],
                "parameters": [
                    { "name": "annee", "in": "query", "schema": { "type": "integer" } },
                    { "name": "mois", "in": "query", "schema": { "type": "integer" } }
                ],
                "responses": {
                    "200": { "description": "KPIs finance", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FinanceKPIs" } } } }
                }
            }
        },
        "/sales/orders": {
            "get": {
                "summary": "Statut des commandes",
                "operationId": "getSalesOrders",
                "tags": ["Sales"],
                "parameters": [
                    { "name": "client_id", "in": "query", "schema": { "type": "integer" } },
                    { "name": "statut", "in": "query", "schema": { "type": "string" } },
                    { "name": "date_from", "in": "query", "schema": { "type": "string", "format": "date" } },
                    { "name": "date_to", "in": "query", "schema": { "type": "string", "format": "date" } },
                    { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } }
                ],
                "responses": {
                    "200": { "description": "Liste commandes", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/SalesOrder" } } } } } } }
                }
            }
        },
        "/iot/realtime": {
            "get": {
                "summary": "Mesures IoT temps réel",
                "operationId": "getIoTRealtime",
                "tags": ["IoT"],
                "parameters": [
                    { "name": "capteur_id", "in": "query", "schema": { "type": "string" } },
                    { "name": "type_mesure", "in": "query", "schema": { "type": "string", "enum": ["temperature", "pression", "humidite"] } },
                    { "name": "minutes", "in": "query", "schema": { "type": "integer", "default": 30, "maximum": 1440 } }
                ],
                "responses": {
                    "200": { "description": "Mesures temps réel", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/IoTMeasure" } } } } } } }
                }
            }
        },
        "/iot/anomalies": {
            "get": {
                "summary": "Anomalies IoT détectées",
                "operationId": "getIoTAnomalies",
                "tags": ["IoT"],
                "parameters": [
                    { "name": "severite", "in": "query", "schema": { "type": "string", "enum": ["info", "warning", "critical"] } },
                    { "name": "hours", "in": "query", "schema": { "type": "integer", "default": 24 } }
                ],
                "responses": {
                    "200": { "description": "Anomalies détectées" }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Client": {
                "type": "object",
                "properties": {
                    "client_id": { "type": "integer" },
                    "raison_sociale": { "type": "string" },
                    "type_client": { "type": "string" },
                    "ville": { "type": "string" },
                    "categorie_abc": { "type": "string" },
                    "ca_12_mois": { "type": "number" }
                }
            },
            "ClientDetail": {
                "allOf": [
                    { "$ref": "#/components/schemas/Client" },
                    {
                        "type": "object",
                        "properties": {
                            "siret": { "type": "string" },
                            "adresse": { "type": "string" },
                            "email": { "type": "string" },
                            "nb_commandes_total": { "type": "integer" },
                            "ca_cumule_ht": { "type": "number" },
                            "score_fidelite": { "type": "number" }
                        }
                    }
                ]
            },
            "FinanceKPIs": {
                "type": "object",
                "properties": {
                    "ca_total_ht": { "type": "number" },
                    "marge_brute_pct": { "type": "number" },
                    "marge_nette_pct": { "type": "number" },
                    "croissance_ca_pct": { "type": "number" },
                    "forecast_ca": { "type": "number" },
                    "ecart_forecast_pct": { "type": "number" }
                }
            },
            "SalesOrder": {
                "type": "object",
                "properties": {
                    "commande_id": { "type": "integer" },
                    "client_id": { "type": "integer" },
                    "date_commande": { "type": "string", "format": "date" },
                    "statut_commande": { "type": "string" },
                    "montant_total_ht": { "type": "number" },
                    "nb_lignes": { "type": "integer" }
                }
            },
            "IoTMeasure": {
                "type": "object",
                "properties": {
                    "capteur_id": { "type": "string" },
                    "type_mesure": { "type": "string" },
                    "valeur_moyenne": { "type": "number" },
                    "valeur_min": { "type": "number" },
                    "valeur_max": { "type": "number" },
                    "timestamp": { "type": "string", "format": "date-time" }
                }
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    },
    "security": [
        { "bearerAuth": [] }
    ]
}
