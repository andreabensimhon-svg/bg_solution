{
    "deployment_pipelines": {
        "name": "dp_bgsolutions",
        "description": "Pipeline de déploiement Fabric : Dev → Test → Prod",
        "stages": [
            {
                "name": "Development",
                "order": 0,
                "workspaceName": "BGSolutions_Dev",
                "description": "Environnement de développement"
            },
            {
                "name": "Test",
                "order": 1,
                "workspaceName": "BGSolutions_Test",
                "description": "Environnement de test / UAT"
            },
            {
                "name": "Production",
                "order": 2,
                "workspaceName": "BGSolutions_Prod",
                "description": "Environnement de production"
            }
        ],
        "rules": [
            {
                "type": "ParameterRule",
                "description": "Adaptation du Lakehouse par environnement",
                "sourceItemType": "Notebook",
                "conditions": {
                    "parameter": "lakehouse_name",
                    "values": {
                        "Development": "lh_bgsolutions_dev",
                        "Test": "lh_bgsolutions_test",
                        "Production": "lh_bgsolutions"
                    }
                }
            },
            {
                "type": "ParameterRule",
                "description": "Adaptation des connexions par environnement",
                "sourceItemType": "Pipeline",
                "conditions": {
                    "parameter": "erp_server",
                    "values": {
                        "Development": "erp-dev.bgsolutions.local",
                        "Test": "erp-test.bgsolutions.local",
                        "Production": "erp.bgsolutions.local"
                    }
                }
            }
        ]
    },
    "git_integration": {
        "provider": "GitHub",
        "repository": "bg_solution",
        "owner": "andreabensimhon-svg",
        "branch": "main",
        "directoryName": "/",
        "connectedWorkspace": "BGSolutions_Dev"
    },
    "artifacts_to_deploy": [
        { "type": "Lakehouse", "name": "lh_bgsolutions" },
        { "type": "Notebook", "pattern": "nb_*" },
        { "type": "Pipeline", "pattern": "pl_*" },
        { "type": "SemanticModel", "name": "BGSolutions_SemanticModel" },
        { "type": "Report", "pattern": "rpt_*" },
        { "type": "Eventstream", "name": "es_iot_capteurs" },
        { "type": "KQLDatabase", "name": "db_iot_realtime" },
        { "type": "RTDashboard", "name": "rtd_capteurs_iot" },
        { "type": "Warehouse", "name": "wh_bgsolutions" },
        { "type": "SparkJobDefinition", "name": "sj_delta_maintenance" },
        { "type": "MLModel", "pattern": "ml_*" }
    ],
    "deployment_checklist": {
        "pre_deployment": [
            "Vérifier que tous les notebooks passent sans erreur en Dev",
            "Vérifier les connexions aux sources de données de l'environnement cible",
            "Valider les paramètres de pipeline pour l'environnement cible",
            "Exécuter les tests de qualité des données"
        ],
        "post_deployment": [
            "Exécuter le pipeline orchestrateur complet",
            "Vérifier le refresh du modèle sémantique",
            "Valider les rapports Power BI",
            "Vérifier le flux Eventstream IoT",
            "Tester les endpoints API"
        ]
    }
}
