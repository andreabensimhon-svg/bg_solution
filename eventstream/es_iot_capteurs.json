{
    "name": "es_iot_capteurs",
    "description": "Eventstream pour l'ingestion temps réel des capteurs IoT vers le Lakehouse et le RT Dashboard",
    "source": {
        "name": "src_iot_capteurs",
        "type": "CustomEndpoint",
        "description": "Endpoint personnalisé pour recevoir les mesures capteurs",
        "properties": {
            "consumerGroup": "$Default",
            "dataFormat": "JSON",
            "eventHubCompatible": true,
            "retentionPeriodInDays": 1,
            "partitionCount": 4
        },
        "schema": {
            "type": "record",
            "name": "IoTEvent",
            "fields": [
                { "name": "event_id", "type": "string" },
                { "name": "capteur_id", "type": "string" },
                { "name": "type_mesure", "type": "string" },
                { "name": "valeur", "type": "double" },
                { "name": "unite", "type": "string" },
                { "name": "timestamp_capteur", "type": "string" },
                { "name": "ligne_production", "type": "string" },
                { "name": "zone", "type": "string" },
                { "name": "qualite_signal", "type": "double" }
            ]
        }
    },
    "transformations": [
        {
            "name": "trx_parse_timestamp",
            "type": "ManageFields",
            "description": "Parse et enrichissement des champs",
            "operations": [
                {
                    "action": "AddField",
                    "fieldName": "event_time",
                    "expression": "CAST(timestamp_capteur AS TIMESTAMP)"
                },
                {
                    "action": "AddField",
                    "fieldName": "ingestion_time",
                    "expression": "SYSTEM.Timestamp()"
                }
            ]
        },
        {
            "name": "trx_filter_invalid",
            "type": "Filter",
            "description": "Filtrer les mesures invalides",
            "expression": "valeur IS NOT NULL AND capteur_id IS NOT NULL AND qualite_signal > 50"
        },
        {
            "name": "trx_aggregate_5min",
            "type": "GroupBy",
            "description": "Agrégation par fenêtre de 5 minutes pour le RT Dashboard",
            "windowType": "Tumbling",
            "windowSize": "5 minutes",
            "groupByFields": ["capteur_id", "type_mesure", "ligne_production", "zone"],
            "aggregations": [
                { "function": "AVG", "field": "valeur", "alias": "valeur_moyenne" },
                { "function": "MIN", "field": "valeur", "alias": "valeur_min" },
                { "function": "MAX", "field": "valeur", "alias": "valeur_max" },
                { "function": "STDEV", "field": "valeur", "alias": "ecart_type" },
                { "function": "COUNT", "field": "*", "alias": "nb_mesures" },
                { "function": "AVG", "field": "qualite_signal", "alias": "qualite_signal_moy" }
            ]
        }
    ],
    "destinations": [
        {
            "name": "dest_lakehouse_bronze",
            "type": "Lakehouse",
            "description": "Écriture des événements bruts dans le Lakehouse Bronze",
            "properties": {
                "workspaceId": "{workspace_id}",
                "lakehouseId": "{lakehouse_id}",
                "tableName": "raw_iot_stream",
                "inputSerialization": {
                    "type": "JSON",
                    "encoding": "UTF-8"
                }
            },
            "sourceTransformation": "trx_filter_invalid"
        },
        {
            "name": "dest_rt_dashboard",
            "type": "CustomEndpoint",
            "description": "Flux agrégé vers le RT Dashboard",
            "properties": {
                "dataFormat": "JSON"
            },
            "sourceTransformation": "trx_aggregate_5min"
        },
        {
            "name": "dest_kql_database",
            "type": "KQLDatabase",
            "description": "Stockage KQL pour les requêtes temps réel avancées",
            "properties": {
                "databaseName": "db_iot_realtime",
                "tableName": "iot_events_raw",
                "mappingRuleName": "iot_mapping"
            },
            "sourceTransformation": "trx_filter_invalid"
        }
    ]
}
