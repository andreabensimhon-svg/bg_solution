{
    "connectors": [
        {
            "name": "conn_erp_sql",
            "type": "SqlServer",
            "description": "Connecteur vers le serveur SQL ERP (finance, opérations, ventes)",
            "connectionProperties": {
                "server": "@{variables('erp_server')}",
                "database": "@{variables('erp_database')}",
                "authenticationType": "ServicePrincipal",
                "tenantId": "@{variables('tenant_id')}",
                "servicePrincipalId": "@{variables('sp_client_id')}",
                "servicePrincipalCredentialType": "KeyVault",
                "keyVaultSecretName": "erp-sql-sp-secret"
            },
            "tables": [
                "dbo.finance_transactions",
                "dbo.bilans_comptables",
                "dbo.sales_orders",
                "dbo.sales_lines",
                "dbo.ordres_fabrication",
                "dbo.supply_chain",
                "dbo.controles_sanitaires",
                "dbo.produits"
            ]
        },
        {
            "name": "conn_bdd_clients",
            "type": "SqlServer",
            "description": "Connecteur vers la BDD clients partagée",
            "connectionProperties": {
                "server": "@{variables('clients_server')}",
                "database": "@{variables('clients_database')}",
                "authenticationType": "ServicePrincipal",
                "tenantId": "@{variables('tenant_id')}",
                "servicePrincipalId": "@{variables('sp_client_id')}",
                "servicePrincipalCredentialType": "KeyVault",
                "keyVaultSecretName": "clients-sql-sp-secret"
            },
            "tables": [
                "dbo.clients"
            ]
        },
        {
            "name": "conn_json_api",
            "type": "RestService",
            "description": "Connecteur REST pour ingestion des commandes JSON depuis les systèmes tiers",
            "connectionProperties": {
                "url": "@{variables('json_api_base_url')}",
                "authenticationType": "OAuth2",
                "tokenEndpoint": "@{variables('oauth_token_url')}",
                "clientId": "@{variables('api_client_id')}",
                "clientSecretKeyVault": "json-api-client-secret"
            },
            "endpoints": [
                "/api/v1/orders",
                "/api/v1/orders/{id}/lines"
            ]
        },
        {
            "name": "conn_mail_exchange",
            "type": "Office365",
            "description": "Connecteur Office 365 pour extraction des mails",
            "connectionProperties": {
                "authenticationType": "ServicePrincipal",
                "tenantId": "@{variables('tenant_id')}",
                "servicePrincipalId": "@{variables('sp_mail_id')}",
                "servicePrincipalCredentialType": "KeyVault",
                "keyVaultSecretName": "mail-sp-secret"
            },
            "scope": "Mail.Read"
        },
        {
            "name": "conn_lakehouse_bronze",
            "type": "Lakehouse",
            "description": "Destination Lakehouse - couche Bronze",
            "connectionProperties": {
                "workspaceId": "@{variables('fabric_workspace_id')}",
                "lakehouseId": "@{variables('lakehouse_id')}"
            }
        },
        {
            "name": "conn_cosmos_db",
            "type": "CosmosDb",
            "description": "Connecteur vers Cosmos DB pour les lectures faible latence",
            "connectionProperties": {
                "accountEndpoint": "@{variables('cosmos_endpoint')}",
                "database": "bgsolutions",
                "authenticationType": "KeyVault",
                "keyVaultSecretName": "cosmos-db-key"
            }
        }
    ]
}
