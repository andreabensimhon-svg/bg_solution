{
    "name": "pl_orchestrator_main",
    "properties": {
        "description": "Pipeline orchestrateur principal - exécute tous les flux d'ingestion puis les transformations Gold",
        "activities": [
            {
                "name": "Ingest_Clients",
                "type": "ExecutePipeline",
                "dependsOn": [],
                "typeProperties": {
                    "pipeline": { "referenceName": "pl_ingest_clients", "type": "PipelineReference" },
                    "waitOnCompletion": true
                }
            },
            {
                "name": "Ingest_ERP_Finance",
                "type": "ExecutePipeline",
                "dependsOn": [],
                "typeProperties": {
                    "pipeline": { "referenceName": "pl_ingest_erp_finance", "type": "PipelineReference" },
                    "waitOnCompletion": true,
                    "parameters": {
                        "LastLoadDate": "@{pipeline().parameters.IncrementalDate}"
                    }
                }
            },
            {
                "name": "Ingest_ERP_Sales",
                "type": "ExecutePipeline",
                "dependsOn": [],
                "typeProperties": {
                    "pipeline": { "referenceName": "pl_ingest_erp_sales", "type": "PipelineReference" },
                    "waitOnCompletion": true,
                    "parameters": {
                        "LastLoadDate": "@{pipeline().parameters.IncrementalDate}"
                    }
                }
            },
            {
                "name": "Ingest_ERP_Operations",
                "type": "ExecutePipeline",
                "dependsOn": [],
                "typeProperties": {
                    "pipeline": { "referenceName": "pl_ingest_erp_operations", "type": "PipelineReference" },
                    "waitOnCompletion": true,
                    "parameters": {
                        "LastLoadDate": "@{pipeline().parameters.IncrementalDate}"
                    }
                }
            },
            {
                "name": "Silver_To_Gold_Finance",
                "type": "SparkNotebook",
                "dependsOn": [
                    { "activity": "Ingest_Clients", "dependencyConditions": ["Succeeded"] },
                    { "activity": "Ingest_ERP_Finance", "dependencyConditions": ["Succeeded"] },
                    { "activity": "Ingest_ERP_Sales", "dependencyConditions": ["Succeeded"] }
                ],
                "typeProperties": {
                    "notebook": { "referenceName": "nb_silver_to_gold_finance", "type": "NotebookReference" }
                }
            },
            {
                "name": "Silver_To_Gold_Sales",
                "type": "SparkNotebook",
                "dependsOn": [
                    { "activity": "Ingest_Clients", "dependencyConditions": ["Succeeded"] },
                    { "activity": "Ingest_ERP_Sales", "dependencyConditions": ["Succeeded"] }
                ],
                "typeProperties": {
                    "notebook": { "referenceName": "nb_silver_to_gold_sales", "type": "NotebookReference" }
                }
            },
            {
                "name": "Silver_To_Gold_Operations",
                "type": "SparkNotebook",
                "dependsOn": [
                    { "activity": "Ingest_ERP_Operations", "dependencyConditions": ["Succeeded"] }
                ],
                "typeProperties": {
                    "notebook": { "referenceName": "nb_silver_to_gold_operations", "type": "NotebookReference" }
                }
            },
            {
                "name": "Silver_To_Gold_IoT",
                "type": "SparkNotebook",
                "dependsOn": [
                    { "activity": "Ingest_ERP_Operations", "dependencyConditions": ["Succeeded"] }
                ],
                "typeProperties": {
                    "notebook": { "referenceName": "nb_silver_to_gold_iot", "type": "NotebookReference" }
                }
            },
            {
                "name": "Refresh_Semantic_Model",
                "type": "WebActivity",
                "dependsOn": [
                    { "activity": "Silver_To_Gold_Finance", "dependencyConditions": ["Succeeded"] },
                    { "activity": "Silver_To_Gold_Sales", "dependencyConditions": ["Succeeded"] },
                    { "activity": "Silver_To_Gold_Operations", "dependencyConditions": ["Succeeded"] },
                    { "activity": "Silver_To_Gold_IoT", "dependencyConditions": ["Succeeded"] }
                ],
                "typeProperties": {
                    "url": "@{pipeline().parameters.SemanticModelRefreshUrl}",
                    "method": "POST",
                    "body": "{}"
                }
            }
        ],
        "parameters": {
            "IncrementalDate": {
                "type": "String",
                "defaultValue": "1900-01-01"
            },
            "SemanticModelRefreshUrl": {
                "type": "String",
                "defaultValue": ""
            }
        }
    }
}
