{
    "name": "pl_ingest_erp_operations",
    "properties": {
        "description": "Pipeline d'ingestion batch des données opérations depuis l'ERP vers le Lakehouse Bronze",
        "activities": [
            {
                "name": "Copy_ERP_Operations",
                "type": "Copy",
                "dependsOn": [],
                "typeProperties": {
                    "source": {
                        "type": "SqlServerSource",
                        "sqlReaderQuery": "SELECT * FROM dbo.ordres_fabrication WHERE date_modification >= '@{pipeline().parameters.LastLoadDate}'"
                    },
                    "sink": {
                        "type": "LakehouseTableSink",
                        "tableActionOption": "Append"
                    },
                    "datasetSink": {
                        "referenceName": "ds_lakehouse_bronze",
                        "type": "DatasetReference",
                        "parameters": { "tableName": "raw_erp_operations" }
                    }
                }
            },
            {
                "name": "Copy_Supply_Chain",
                "type": "Copy",
                "dependsOn": [],
                "typeProperties": {
                    "source": {
                        "type": "SqlServerSource",
                        "sqlReaderQuery": "SELECT * FROM dbo.supply_chain WHERE date_modification >= '@{pipeline().parameters.LastLoadDate}'"
                    },
                    "sink": {
                        "type": "LakehouseTableSink",
                        "tableActionOption": "Append"
                    },
                    "datasetSink": {
                        "referenceName": "ds_lakehouse_bronze",
                        "type": "DatasetReference",
                        "parameters": { "tableName": "raw_supply_chain" }
                    }
                }
            },
            {
                "name": "Copy_Process_Sanitaire",
                "type": "Copy",
                "dependsOn": [],
                "typeProperties": {
                    "source": {
                        "type": "SqlServerSource",
                        "sqlReaderQuery": "SELECT * FROM dbo.controles_sanitaires"
                    },
                    "sink": {
                        "type": "LakehouseTableSink",
                        "tableActionOption": "Append"
                    },
                    "datasetSink": {
                        "referenceName": "ds_lakehouse_bronze",
                        "type": "DatasetReference",
                        "parameters": { "tableName": "raw_process_sanitaire" }
                    }
                }
            },
            {
                "name": "Notebook_Bronze_To_Silver_Operations",
                "type": "SparkNotebook",
                "dependsOn": [
                    { "activity": "Copy_ERP_Operations", "dependencyConditions": ["Succeeded"] },
                    { "activity": "Copy_Supply_Chain", "dependencyConditions": ["Succeeded"] },
                    { "activity": "Copy_Process_Sanitaire", "dependencyConditions": ["Succeeded"] }
                ],
                "typeProperties": {
                    "notebook": {
                        "referenceName": "nb_bronze_to_silver_operations",
                        "type": "NotebookReference"
                    }
                }
            }
        ],
        "parameters": {
            "LastLoadDate": {
                "type": "String",
                "defaultValue": "1900-01-01"
            }
        }
    }
}
