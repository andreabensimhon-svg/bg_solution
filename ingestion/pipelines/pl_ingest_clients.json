{
    "name": "pl_ingest_clients",
    "properties": {
        "description": "Pipeline d'ingestion de la BDD clients partagée vers le Lakehouse Bronze",
        "activities": [
            {
                "name": "Copy_BDD_Clients",
                "type": "Copy",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.01:00:00",
                    "retry": 3,
                    "retryIntervalInSeconds": 30
                },
                "typeProperties": {
                    "source": {
                        "type": "SqlServerSource",
                        "sqlReaderQuery": "SELECT * FROM dbo.clients"
                    },
                    "sink": {
                        "type": "LakehouseTableSink",
                        "tableActionOption": "Overwrite"
                    },
                    "datasetSource": {
                        "referenceName": "ds_bdd_clients",
                        "type": "DatasetReference"
                    },
                    "datasetSink": {
                        "referenceName": "ds_lakehouse_bronze",
                        "type": "DatasetReference",
                        "parameters": { "tableName": "raw_clients" }
                    }
                }
            },
            {
                "name": "Copy_Produits",
                "type": "Copy",
                "dependsOn": [],
                "typeProperties": {
                    "source": {
                        "type": "SqlServerSource",
                        "sqlReaderQuery": "SELECT * FROM dbo.produits WHERE actif = 1"
                    },
                    "sink": {
                        "type": "LakehouseTableSink",
                        "tableActionOption": "Overwrite"
                    },
                    "datasetSink": {
                        "referenceName": "ds_lakehouse_bronze",
                        "type": "DatasetReference",
                        "parameters": { "tableName": "raw_produits" }
                    }
                }
            },
            {
                "name": "Notebook_Bronze_To_Silver_Clients",
                "type": "SparkNotebook",
                "dependsOn": [
                    { "activity": "Copy_BDD_Clients", "dependencyConditions": ["Succeeded"] }
                ],
                "typeProperties": {
                    "notebook": {
                        "referenceName": "nb_bronze_to_silver_clients",
                        "type": "NotebookReference"
                    }
                }
            }
        ]
    }
}
