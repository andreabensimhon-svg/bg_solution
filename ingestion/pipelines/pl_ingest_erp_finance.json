{
    "name": "pl_ingest_erp_finance",
    "properties": {
        "description": "Pipeline d'ingestion batch des données financières depuis l'ERP vers le Lakehouse Bronze",
        "activities": [
            {
                "name": "Copy_ERP_Finance_Transactions",
                "type": "Copy",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.02:00:00",
                    "retry": 2,
                    "retryIntervalInSeconds": 60
                },
                "typeProperties": {
                    "source": {
                        "type": "SqlServerSource",
                        "sqlReaderQuery": "SELECT * FROM dbo.finance_transactions WHERE date_modification >= '@{pipeline().parameters.LastLoadDate}'"
                    },
                    "sink": {
                        "type": "LakehouseTableSink",
                        "tableActionOption": "Append"
                    },
                    "datasetSource": {
                        "referenceName": "ds_erp_sql_finance",
                        "type": "DatasetReference"
                    },
                    "datasetSink": {
                        "referenceName": "ds_lakehouse_bronze",
                        "type": "DatasetReference",
                        "parameters": {
                            "tableName": "raw_erp_finance"
                        }
                    }
                }
            },
            {
                "name": "Copy_ERP_Bilans",
                "type": "Copy",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.01:00:00",
                    "retry": 2,
                    "retryIntervalInSeconds": 60
                },
                "typeProperties": {
                    "source": {
                        "type": "SqlServerSource",
                        "sqlReaderQuery": "SELECT * FROM dbo.bilans_comptables"
                    },
                    "sink": {
                        "type": "LakehouseTableSink",
                        "tableActionOption": "Overwrite"
                    },
                    "datasetSource": {
                        "referenceName": "ds_erp_sql_bilans",
                        "type": "DatasetReference"
                    },
                    "datasetSink": {
                        "referenceName": "ds_lakehouse_bronze",
                        "type": "DatasetReference",
                        "parameters": {
                            "tableName": "raw_erp_bilans"
                        }
                    }
                }
            },
            {
                "name": "Notebook_Bronze_To_Silver_Finance",
                "type": "SparkNotebook",
                "dependsOn": [
                    {
                        "activity": "Copy_ERP_Finance_Transactions",
                        "dependencyConditions": ["Succeeded"]
                    },
                    {
                        "activity": "Copy_ERP_Bilans",
                        "dependencyConditions": ["Succeeded"]
                    }
                ],
                "typeProperties": {
                    "notebook": {
                        "referenceName": "nb_bronze_to_silver_finance",
                        "type": "NotebookReference"
                    },
                    "conf": {
                        "spark.fabric.lakehouse": "@{pipeline().parameters.LakehouseName}"
                    }
                }
            }
        ],
        "parameters": {
            "LastLoadDate": {
                "type": "String",
                "defaultValue": "1900-01-01"
            },
            "LakehouseName": {
                "type": "String",
                "defaultValue": "lh_bgsolutions"
            }
        }
    }
}
